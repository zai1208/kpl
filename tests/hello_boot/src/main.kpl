; Boot-tested Hello World: writes to both the VGA text buffer and the
; COM1 serial port. Runs after boot32.asm has already put the CPU into
; long mode - by the time kpl_main is called, this is ordinary KPL.

PROC serial_init() {
    ASM {
        mov dx, 0x3F9
        mov al, 0x00
        out dx, al
        mov dx, 0x3FB
        mov al, 0x80
        out dx, al
        mov dx, 0x3F8
        mov al, 0x03
        out dx, al
        mov dx, 0x3F9
        mov al, 0x00
        out dx, al
        mov dx, 0x3FB
        mov al, 0x03
        out dx, al
        mov dx, 0x3FA
        mov al, 0xC7
        out dx, al
        mov dx, 0x3FC
        mov al, 0x0B
        out dx, al
    }
}

PROC serial_putc(ch: u64) {
    ASM {
    .wait:
        mov dx, 0x3FD
        in al, dx
        test al, 0x20
        jz .wait
        mov al, [ch]
        mov dx, 0x3F8
        out dx, al
    }
}

; row/col -> VGA text-buffer address is (row*80 + col)*2 + 0xB8000, split
; across three locals since KPL allows only one operator per line.
PROC vga_putc(row: u64, col: u64, ch: u64) {
    u64 t1 = row * 80
    u64 t2 = t1 + col
    u64 t3 = t2 * 2
    u64 addr = t3 + 753664
    ASM {
        mov rax, [addr]
        mov bl, [ch]
        mov [rax], bl
        mov byte [rax+1], 15
    }
}

PROC kpl_main() {
    serial_init()

    vga_putc(0, 0, 72)
    vga_putc(0, 1, 101)
    vga_putc(0, 2, 108)
    vga_putc(0, 3, 108)
    vga_putc(0, 4, 111)
    vga_putc(0, 5, 44)
    vga_putc(0, 6, 32)
    vga_putc(0, 7, 87)
    vga_putc(0, 8, 111)
    vga_putc(0, 9, 114)
    vga_putc(0, 10, 108)
    vga_putc(0, 11, 100)
    vga_putc(0, 12, 33)

    serial_putc(72)
    serial_putc(101)
    serial_putc(108)
    serial_putc(108)
    serial_putc(111)
    serial_putc(44)
    serial_putc(32)
    serial_putc(87)
    serial_putc(111)
    serial_putc(114)
    serial_putc(108)
    serial_putc(100)
    serial_putc(33)
    serial_putc(10)

    ASM {
        cli
    .halt:
        hlt
        jmp .halt
    }
}
