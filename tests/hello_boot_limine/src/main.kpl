; Boot-tested "Hello, World!" over Limine's native protocol, at the real
; higher-half address (0xFFFFFFFF80000000) the rest of this toolchain's
; test fixtures already assume.
;
; Fourth generation of this same demo. Each version removed one more
; layer of hand-written assembly as the language grew the syntax to
; express what was underneath it:
;   1. Hand-rolled the entire pixel loop (no struct access at all).
;   2. Real STRUCT field access, but still needed a hand-written
;      accessor to chase request->response->framebuffers[0].
;   3. Real PROC return values collapsed the accessor call down to one
;      line - but the chase itself (two levels of pointer indirection
;      plus an array index) still had to happen *inside* that accessor,
;      in hand-written asm, because `->` only went one hop deep.
;   4. This version: `->` chains arbitrarily deep, and a literal `[N]`
;      indexes a pointer-array - so the chase itself is real KPL now.
;      The only hand-written code left is get_request_ptr() (KPL has no
;      address-of operator to reach an external data symbol directly)
;      and write_pixel32() (KPL can't write through a computed pointer
;      value) - see limine_reqs.asm.
;
; The struct layout below matches Limine's real limine_framebuffer_
; request / _response / limine_framebuffer structs field-for-field (see
; limine_reqs.asm's comments for the byte offsets this produces).

STRUCT Framebuffer {
    ptr address
    u64 width
    u64 height
    u64 pitch
}

STRUCT LimineResponse {
    u64 revision
    u64 framebuffer_count
    ptr framebuffers
}

STRUCT FramebufferRequest {
    u64 id0
    u64 id1
    u64 id2
    u64 id3
    u64 revision
    LimineResponse response
}

PROC serial_init() {
    ASM {
        mov dx, 0x3F9
        mov al, 0x00
        out dx, al
        mov dx, 0x3FB
        mov al, 0x80
        out dx, al
        mov dx, 0x3F8
        mov al, 0x03
        out dx, al
        mov dx, 0x3F9
        mov al, 0x00
        out dx, al
        mov dx, 0x3FB
        mov al, 0x03
        out dx, al
        mov dx, 0x3FA
        mov al, 0xC7
        out dx, al
        mov dx, 0x3FC
        mov al, 0x0B
        out dx, al
    }
}

PROC serial_putc(ch: u64) {
    ASM {
    .wait:
        mov dx, 0x3FD
        in al, dx
        test al, 0x20
        jz .wait
        mov al, [ch]
        mov dx, 0x3F8
        out dx, al
    }
}

PROC kpl_main() {
    FramebufferRequest req = get_request_ptr()

    ; The pointer chase itself: two struct hops, then a literal array
    ; index - all real KPL, all one flat expression each.
    Framebuffer fb = req->response->framebuffers[0]

    u64 addr = fb->address
    u64 width = fb->width
    u64 height = fb->height
    u64 pitch = fb->pitch

    u64 y = 0
    loop y < height {
        u64 x = 0
        loop x < width {
            u64 nx1 = x * 255
            u64 nX = nx1 / width
            u64 ny1 = y * 255
            u64 nY = ny1 / height

            ; (nY << 8) | nX, without shift/OR - nY*256 == nY<<8, and
            ; nY*256+nX == (nY<<8)|nX since nX never exceeds 255.
            u64 ny2 = nY * 256
            u64 color = ny2 + nX

            u64 row_off = y * pitch
            u64 col_off = x * 4
            u64 off1 = row_off + col_off
            u64 pix_addr = off1 + addr

            write_pixel32(pix_addr, color)

            x = x + 1
        }
        y = y + 1
    }

    serial_init()
    serial_putc(72)
    serial_putc(101)
    serial_putc(108)
    serial_putc(108)
    serial_putc(111)
    serial_putc(44)
    serial_putc(32)
    serial_putc(87)
    serial_putc(111)
    serial_putc(114)
    serial_putc(108)
    serial_putc(100)
    serial_putc(33)
    serial_putc(10)

    ASM {
        cli
    .halt:
        hlt
        jmp .halt
    }
}
